{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "./",
    "paths": {
      "@helpers/*": ["helpers/*"],
      "@utils/*": ["utils/*"],
      "@pages/*": ["pages/*"],
      "@tests/*": ["tests/*"]
    }
  }
}